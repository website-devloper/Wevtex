# ── Contact form email (Resend) ─────────────────────────────
# Used by app/api/contact/route.ts to deliver leads from the home form.

# Your Resend API key — create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Inbox that receives new lead notifications (e.g. leads@wevtex.com)
LEAD_NOTIFY_EMAIL=leads@wevtex.com

# Verified Resend sender. The domain must be verified in Resend.
# Format: "Display Name <address@yourdomain>"
LEAD_FROM_EMAIL=Wevtex <hello@wevtex.com>

# ── Analytics (GA4) ─────────────────────────────────────────
# Google Analytics 4 Measurement ID. Find it in GA4: Admin → Data Streams.
# Public by design (NEXT_PUBLIC_ vars reach the browser). Leave blank to disable.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
